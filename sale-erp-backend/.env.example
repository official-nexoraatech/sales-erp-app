# Optional database overrides. Without them, local development uses
# jdbc:postgresql://localhost:5432/billtop_db with postgres/root.
# For Supabase, copy the Session pooler parameters from Dashboard > Connect.
# The pooler username must be postgres.<project-ref>, not only postgres.
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.<project-ref>
SPRING_DATASOURCE_PASSWORD=replace-with-current-database-password

PORT=8081
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=nexoraa-billing-top
AWS_S3_PUBLIC_URL=https://nexoraa-billing-top.s3.ap-south-1.amazonaws.com

# Email provider SMTP configuration
MAIL_HOST=smtpout.secureserver.net
MAIL_PORT=465
MAIL_USERNAME=contact@nexoraatech.com
MAIL_PASSWORD=replace-with-email-password
MAIL_FROM=contact@nexoraatech.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_SSL_ENABLE=true
MAIL_SMTP_STARTTLS_ENABLE=false

API_BASE_URL=http://localhost:8081
API_TEST_USERNAME=
API_TEST_PASSWORD=
