{
  "name": "@erp/tenant-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file ../../.env src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "bootstrap-operator": "tsx scripts/bootstrap-platform-operator.ts",
    "reset-operator-password": "tsx scripts/reset-platform-operator-password.ts"
  },
  "dependencies": {
    "@erp/config": "workspace:*",
    "@erp/db": "workspace:*",
    "@erp/logger": "workspace:*",
    "@erp/sdk": "workspace:*",
    "@erp/types": "workspace:*",
    "@erp/utils": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.1.0",
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.9.0",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  }
}
