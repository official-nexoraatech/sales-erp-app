  "dependencies": {
    "@erp/config": "workspace:*",
    "@erp/db": "workspace:*",
    "@erp/logger": "workspace:*",
    "@erp/sdk": "workspace:*",
    "@erp/types": "workspace:*",
    "@erp/utils": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.1.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.9.0",
    "jose": "^5.9.6",
    "kafkajs": "^2.2.4",
    "qrcode": "^1.5.4",
    "ulid": "^2.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
