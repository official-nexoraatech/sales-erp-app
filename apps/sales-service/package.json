{
  "name": "@erp/sales-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file ../../.env src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint src/",
