{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "title": "ERP — Enterprise Hardening Dashboard (Phase 13)",
  "uid": "erp-phase13-hardening",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "graphTooltip": 1,
  "tags": ["erp", "phase13", "hardening"],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "1. Service Overview — Request Rate, Error Rate, Latency P50/P95/P99", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" }, "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1, "title": "Request Rate — All Services (RPS)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_requests_total[1m])) by (service)", "legendFormat": "{{ service }}", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }, "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2, "title": "HTTP Error Rate — All Services",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (service) / sum(rate(http_requests_total[5m])) by (service)", "legendFormat": "{{ service }} 5xx rate", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_requests_total{status=~\"4..\"}[5m])) by (service) / sum(rate(http_requests_total[5m])) by (service)", "legendFormat": "{{ service }} 4xx rate", "refId": "B" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 }, "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3, "title": "Latency P50/P95/P99 — All Services",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_ms_bucket[5m])) by (le, service))", "legendFormat": "p50 {{ service }}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket[5m])) by (le, service))", "legendFormat": "p95 {{ service }}", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_ms_bucket[5m])) by (le, service))", "legendFormat": "p99 {{ service }}", "refId": "C" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }, "id": 101, "title": "2. Infrastructure — CPU, Memory, Disk, Network per Pod", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4, "title": "CPU Usage per Pod (namespace: erp-system)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"erp-system\", container!=\"\"}[5m])) by (pod)", "legendFormat": "{{ pod }}", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 5, "title": "Memory Usage per Pod (namespace: erp-system)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(container_memory_usage_bytes{namespace=\"erp-system\", container!=\"\"}) by (pod)", "legendFormat": "{{ pod }}", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 18 },
      "id": 6, "title": "Network I/O per Node (bytes/sec)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(node_network_receive_bytes_total[5m])) by (instance)", "legendFormat": "{{ instance }} rx", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(node_network_transmit_bytes_total[5m])) by (instance)", "legendFormat": "{{ instance }} tx", "refId": "B" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } }, "overrides": [] },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 18 },
      "id": 7, "title": "Disk Usage per Node",
      "type": "gauge",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})", "legendFormat": "{{ instance }} disk used", "refId": "A" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }, "id": 102, "title": "3. Business Health — Invoices/hour, Failed Rate, DLQ Depth", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "bars", "fillOpacity": 50 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 25 },
      "id": 8, "title": "Invoices Created per Hour",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(erp_invoice_create_total[1h])", "legendFormat": "invoices/hr", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 25 },
      "id": 9, "title": "Invoice Failure Rate",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(erp_invoice_create_failed_total[5m])) / sum(rate(erp_invoice_create_total[5m]))", "legendFormat": "invoice fail rate", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }] } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 25 },
      "id": 10, "title": "DLQ Depth by Topic",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(erp_dlq_depth) by (topic)", "legendFormat": "{{ topic }}", "refId": "A" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 }, "id": 103, "title": "4. Database — Query Time, Connection Count, Replication Lag", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 34 },
      "id": 11, "title": "PostgreSQL — Avg Query Time",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(pg_stat_statements_total_time[5m]) / rate(pg_stat_statements_calls[5m])", "legendFormat": "avg query time", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 34 },
      "id": 12, "title": "PostgreSQL — Active Connections",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(pg_stat_activity_count{state=\"active\"}) by (datname)", "legendFormat": "{{ datname }} active", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(pg_stat_activity_count{state=\"idle\"}) by (datname)", "legendFormat": "{{ datname }} idle", "refId": "B" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 30 }] } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 34 },
      "id": 13, "title": "PostgreSQL — Replication Lag",
      "type": "gauge",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "pg_replication_lag_seconds", "legendFormat": "replication lag", "refId": "A" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 }, "id": 104, "title": "5. Kafka — Consumer Lag per Consumer Group", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "id": 14, "title": "Kafka Consumer Lag by Consumer Group",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(kafka_consumer_group_lag) by (consumergroup, topic)", "legendFormat": "{{ consumergroup }} / {{ topic }}", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "id": 15, "title": "Kafka — Messages In/Out per Second",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(kafka_server_BrokerTopicMetrics_MessagesIn_total[1m])) by (topic)", "legendFormat": "{{ topic }} in", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(kafka_server_BrokerTopicMetrics_BytesOut_total[1m])) by (topic)", "legendFormat": "{{ topic }} out bytes", "refId": "B" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 }, "id": 105, "title": "6. Saga — Active, Failed, Compensation Rate", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } }, "overrides": [] },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 52 },
      "id": 16, "title": "Active Sagas",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(erp_saga_active_count)", "legendFormat": "active sagas", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 52 },
      "id": 17, "title": "Stalled Sagas (> 30 min)",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(erp_saga_stalled_count)", "legendFormat": "stalled", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] } }, "overrides": [] },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 52 },
      "id": 18, "title": "Failed Sagas (last 1h)",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "increase(erp_saga_failed_total[1h])", "legendFormat": "failed/hr", "refId": "A" }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 52 },
      "id": 19, "title": "Saga Compensation Rate",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(erp_saga_compensation_total[10m]) / rate(erp_saga_total[10m])", "legendFormat": "compensation rate", "refId": "A" }
      ]
    }
  ],

  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser"
}
